{
  "name": "draftpkg",
  "version": "0.1.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/sarahdayan/draftpkg",
    "directory": "packages/cli"
  },
  "bin": {
    "draftpkg": "dist/cli.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "prebuild": "tsx scripts/embed-worker.ts",
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/cli.mjs",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "memfs": "^4.56.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.1"
  }
}
