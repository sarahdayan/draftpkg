{
  "name": "draftpkg",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "draftpkg": "dist/cli.mjs"
  },
  "scripts": {
    "build": "esbuild src/cli.ts --bundle --platform=node --target=node20 --format=esm --outfile=dist/cli.mjs",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^25.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.9.2",
    "vitest": "^3.2.1"
  }
}
